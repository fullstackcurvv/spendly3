{
  "name": "spendly-landing-sdk",
  "version": "1.0.1",
  "description": "Reusable Spendly landing page SDK",
  "type": "module",
  "main": "./dist/spendly-landing-sdk.umd.cjs",
  "module": "./dist/spendly-landing-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/spendly-landing-sdk.js",
      "require": "./dist/spendly-landing-sdk.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declarationDir dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
